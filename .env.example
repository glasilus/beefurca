# Server settings
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://beefurca:beefurca_secure_password@localhost:5432/beefurca_db

# Redis
REDIS_URL=redis://localhost:6379

# Cryptographic secrets for RS256/EdDSA JWT
# Can be local paths to PEM files, or the keys themselves in production envs
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_PRIVATE_KEY_PATH=keys/private.pem

# Token Expire Times (TTL)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Bootstrap Admin Configuration
BOOTSTRAP_ADMIN_EMAIL=admin@beefurca.com
BOOTSTRAP_ADMIN_PASSWORD=change_this_to_a_secure_password
BOOTSTRAP_ADMIN_NICKNAME=SuperAdmin

# CORS: список разрешённых источников фронтендов через запятую
# (прод: домен веба на Vercel; dev: localhost)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# URL фронтенда — куда редиректить после успешного входа через Discord
FRONTEND_URL=http://localhost:3000

# Discord OAuth (https://discord.com/developers/applications)
# Redirect URI должен совпадать с настроенным в приложении Discord и указывать
# на бэкенд: <API_URL>/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5000/auth/discord/callback
